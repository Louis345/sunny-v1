{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/tests/test-canvas-overflow.ts",
    "src/tests/test-canvas-svg-render.ts",
    "src/tests/test-tool-filtering.ts",
    "src/tests/test-canvas-ownership.ts",
    "src/tests/test-context-injection.ts",
    "src/tests/test-session-type-resolution.ts",
    "src/tests/test-assignment-manifest.ts",
    "src/tests/test-svg-strip.ts",
    "src/tests/test-canvas-description-sanitizer.ts",
    "src/tests/test-worksheet-stale-answer.ts",
    "vitest.config.ts"
  ]
}
