{
  "name": "sunny",
  "version": "0.1.0",
  "description": "Project Sunny — AI therapeutic learning companion",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npx tsx src/scripts/launch-kiosk.ts --no-browser",
    "dev": "npx tsx src/index.ts",
    "ila": "npx tsx src/sessions/ila.ts",
    "reina": "npx tsx src/sessions/reina.ts",
    "plan-ila": "npx tsx src/agents/curriculum-planner/planner.ts ila",
    "plan-reina": "npx tsx src/agents/curriculum-planner/planner.ts reina",
    "ingest": "npx tsx src/agents/ingester/ingest.ts",
    "convert-pdfs": "npx tsx src/scripts/convert-pdfs-to-txt.ts",
    "voice-showdown": "npx tsx src/voice-showdown.ts",
    "test:psychologist": "npx tsx src/scripts/test-psychologist.ts",
    "test:latency": "npx tsx src/scripts/test-latency.ts",
    "test:tools": "npx tsx src/tests/test-tools.ts",
    "test:canvas": "npx tsx src/scripts/test-canvas.ts",
    "server": "npx tsx src/server.ts",
    "web": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "sunny": "cd web && npm run build && cd .. && npx tsx src/scripts/launch-kiosk.ts",
    "sunny:test": "SUNNY_TEST_MODE=true npx tsx src/server.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@anthropic-ai/sdk": "^0.39.0",
    "@deepgram/sdk": "^5.0.0",
    "@elevenlabs/elevenlabs-js": "^2.37.0",
    "ai": "^6.0.116",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "unpdf": "^1.4.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
