node_modules/
dist/
.env
.DS_Store
**/.DS_Store
*.js.map
src/**/*.js

# Reference repo for AI Agents course (Frontend Masters)
_reference/

# Auto-generated at startup
CANVAS_CAPABILITIES.md

# Session prompt cache (buildSessionPrompt, 24h TTL)
.prompt-cache/

# Runtime server audit logs (local only; may contain transcripts)
logs/sessions/

# Homework — runtime data, never committed (repo root only; not src/tests/fixtures/homework)
/homework/
# Auditable homework care plans are regenerated on ingest and may contain private assignment details
src/context/*/homework/pending/**/learning-plan.*

# Document ingester — private documents not committed
src/intake/ila/*.txt
src/intake/ila/*.md
src/intake/ila/*.json
src/intake/reina/*.txt
src/intake/reina/*.md
src/intake/reina/*.json
src/intake/processed/
# macOS / device screenshots dropped into intake (large binaries)
src/intake/**/Screen Shot*.png

# Drop folder — private documents not committed
drop/*.png
drop/*.jpg
drop/*.jpeg
drop/*.pdf
drop/*.txt
drop/*.md
drop/*.vtt
drop/processed/
drop/ila/
drop/reina/

# Companion VRM models (large binaries; fetch via npm run sunny:download:companion-vrms)
web/public/companions/*.vrm

# Companion Mixamo FBX clips (large binaries; paths stay in animationRegistry)
web/public/animations/*.fbx
# NOTE: web/public/animations/*.json sidecars ARE committed (small metadata files)
# NOTE: src/shared/companions/animations.generated.ts IS committed (generated from sidecars)

# Local Rive explorer (HTML + character.riv); delete when done
rive-demo/

# Python (pipeline local venv — never commit)
venv/
__pycache__/
*.pyc
src/pipeline/venv/
src/pipeline/__pycache__/
src/pipeline/.pytest_cache/
