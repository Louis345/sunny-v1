ANTHROPIC_API_KEY=your-anthropic-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Per-child voice IDs (auto-populated when each child picks their voice)
# ELEVENLABS_VOICE_ID_ILA=
# ELEVENLABS_VOICE_ID_REINA=   # default in code: Gigi jBpfuIE2acCO8z3wKNLl unless set
# Diagnostics / demo (SUNNY_SUBJECT=diag): default TTS voice is Charlotte premade unless overridden
# Override: npm run voice-creator  |  TTS on: npm run sunny:mode:diag  |  TTS off (save $): npm run sunny:mode:diag:mute
# ELEVENLABS_VOICE_ID_DIAG=

# Pronunciation dictionary (auto-populated by: npx tsx src/setup-dictionary.ts)
# ELEVENLABS_PRONUNCIATION_DICT_ID=
# ELEVENLABS_PRONUNCIATION_DICT_VERSION=

# Grok / xAI for story images (optional — no key = skip). Uses POST /v1/images/generations.
# GROK_API_KEY=
# Optional override (default: grok-imagine-image)
# GROK_IMAGE_MODEL=grok-imagine-image